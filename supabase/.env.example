# ============================================================================
# SUPABASE ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env.local and fill in your Supabase credentials
# ============================================================================

# Supabase Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Service Role Key (for backend operations)
# Get this from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Anon Key (for client-side operations)
# Get this from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_ANON_KEY=your-anon-key

# Application URL (for email links and redirects)
APP_URL=http://localhost:3000

# Frontend Origin (for CORS)
FRONTEND_ORIGIN=http://localhost:3000

# Email Configuration (optional - for production email sending)
# RESEND_API_KEY=your-resend-api-key
# FROM_EMAIL=noreply@yourdomain.com

# OpenAI API Key (optional - for AI features)
# OPENAI_API_KEY=your-openai-api-key

# Weather API Key (optional - for weather data)
# WEATHER_API_KEY=your-weather-api-key

# ============================================================================
# NOTES
# ============================================================================
# 1. Never commit this file with actual credentials
# 2. Use different values for development and production
# 3. The service role key should only be used on the server
# 4. The anon key can be used on the client with RLS policies
# ============================================================================
