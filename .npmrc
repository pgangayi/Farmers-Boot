# npmrc configuration for Farmers Boot turborepo
# This file ensures proper workspace behavior

# Enable workspaces
workspaces=true

# Use workspace protocol for local dependencies
# This ensures that @farmers-boot/shared resolves correctly
workspace-links=true

# Prefer workspace versions over registry versions
prefer-workspace-packages=true

# Set strict peer dependencies to avoid issues
strict-peer-dependencies=false

# Save exact versions for reproducibility
save-exact=true

# Use npm workspaces protocol
# This is important for turborepo to work correctly
legacy-peer-deps=false
