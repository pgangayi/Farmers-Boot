{
  "name": "@farmers-boot/shared",
  "version": "0.1.0",
  "description": "Shared types and utilities for Farmers Boot",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "node -e \"const fs=require('fs');try{fs.rmSync('dist',{recursive:true,force:true})}catch(e){}\"",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "keywords": [
    "farmers-boot",
    "shared",
    "types",
    "utilities"
  ],
  "author": "Farmers Boot Team",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.2.2",
    "react": "^18.2.0",
    "@types/react": "^18.2.43"
  },
  "dependencies": {
    "zod": "^4.3.5",
    "date-fns": "^4.1.0"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.95.3"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    }
  }
}
